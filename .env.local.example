# ============================================================
# VARIABLES D'ENVIRONNEMENT — Elio Robotics
# ============================================================
# Copier ce fichier en .env.local (jamais committer .env.local)
# Sur Vercel : ajouter ces variables dans Settings > Environment Variables
# ============================================================

# --- RESEND (envoi email formulaire contact) ---
# Obtenir la clé sur https://resend.com → API Keys
# Compte gratuit : 3 000 emails/mois, 100/jour
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX

# Adresse de destination des formulaires
# Modifier si l'adresse de réception change
CONTACT_EMAIL=contact@elio-robot.fr

# Adresse d'expédition :
#   SANS domaine vérifié → laisser commenté (utilise onboarding@resend.dev)
#   AVEC domaine elio-robot.fr vérifié → décommenter et renseigner
# RESEND_FROM_EMAIL=Formulaire Elio <noreply@elio-robot.fr>

# --- FIREBASE (analytics uniquement, optionnel) ---
# Ces variables sont déjà dans le code Firebase — laisser telles quelles
# si Firebase Analytics est conservé.
